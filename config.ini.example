# change-of-system configuration file.
# Lines starting with '#' or ';' are comments.
# Values shown below are the defaults.

# ------------------------------
# Filesystem monitor
# ------------------------------
filesystem.enabled = true
filesystem.poll_interval_ms = 2000
filesystem.use_native = true
# Comma-separated list of directories or files to watch.
filesystem.watch_paths = /etc, /tmp

# ------------------------------
# Process monitor
# ------------------------------
process.enabled = true
process.poll_interval_ms = 3000
process.track_cpu = true
process.track_memory = true

# ------------------------------
# Network monitor
# ------------------------------
network.enabled = true
network.poll_interval_ms = 5000

# ------------------------------
# System config monitor
# ------------------------------
system_config.enabled = true
system_config.poll_interval_ms = 10000

# ------------------------------
# User activity monitor
# ------------------------------
user_activity.enabled = true
user_activity.poll_interval_ms = 5000

# ------------------------------
# Service monitor
# ------------------------------
service.enabled = true
service.poll_interval_ms = 10000

# ------------------------------
# File integrity monitor
# ------------------------------
file_integrity.enabled = true
file_integrity.poll_interval_ms = 30000
# Comma-separated list of files to monitor for integrity changes
file_integrity.watch_files = /etc/passwd, /etc/shadow, /etc/sudoers

# ------------------------------
# Storage
# ------------------------------
storage.database_path = change-of-system.log
storage.max_events = 100000

# ------------------------------
# Remote reporting (optional)
# ------------------------------
reporting.enabled = false
reporting.endpoint = https://example.com/api/events
reporting.api_key =
reporting.batch_size = 100
reporting.interval_ms = 10000

# ------------------------------
# Alert system
# ------------------------------
# Enable/disable alert system
alert.enabled = true

# Predefined alert rules are loaded by default:
# - high_cpu_usage: Triggered when process uses high CPU
# - suspicious_process: Detects suspicious process activity
# - critical_file_change: Monitors critical system files
# - network_anomaly: Detects unusual network activity
# - config_tampering: Monitors system configuration changes
# - rapid_file_changes: Detects rapid file modifications

# ------------------------------
# Event filter
# ------------------------------
# Enable/disable event filtering
filter.enabled = false

# Predefined filter rules (when filter.enabled = true):
# - ignore_temp_files: Ignore events in /tmp directory
# - ignore_log_files: Ignore log file changes
# - ignore_browser_cache: Ignore browser cache changes

# ------------------------------
# Statistics
# ------------------------------
# Statistics are always collected and available via API
# No configuration needed
